<odoo>
    <record id="project_project_view_form_nextcloud" model="ir.ui.view">
        <field name="name">project.project.form.nextcloud</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Nextcloud Dosyaları" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer">
                    <group>
                        <button name="action_nextcloud_upload_wizard" type="object" string="Nextcloud'a Dosya Yükle" class="btn-primary" groups="odoo_nextcloud_document_hub.group_nextcloud_document_uploader"/>
                    </group>
                    <field name="nextcloud_document_ids" nolabel="1" readonly="1">
                        <list create="false" edit="false">
                            <field name="name"/>
                            <field name="project_code"/>
                            <field name="project_name"/>
                            <field name="uploaded_by"/>
                            <field name="upload_date"/>
                            <field name="state"/>
                            <field name="is_previewable" column_invisible="True"/>
                            <field name="can_download" column_invisible="True"/>
                            <field name="can_request_download" column_invisible="True"/>
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="error_message" optional="hide"/>
                            <field name="nextcloud_path"/>
                            <button name="action_preview" string="Önizle" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="state != 'uploaded' or not is_previewable"/>
                            <button name="action_rename_wizard" string="Ad Değiştir" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_manager,base.group_system"/>
                            <button name="action_download" string="İndir" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer,base.group_system" invisible="not can_download"/>
                            <button name="action_request_download" string="İndirme Talep Et" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="not can_request_download"/>
                            <button name="action_open_nextcloud" string="Nextcloud'da Aç" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="state != 'uploaded'"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
