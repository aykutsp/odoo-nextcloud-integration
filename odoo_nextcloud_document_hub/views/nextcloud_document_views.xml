<odoo>
    <record id="view_nextcloud_document_list" model="ir.ui.view">
        <field name="name">nextcloud.document.list</field>
        <field name="model">nextcloud.document</field>
        <field name="arch" type="xml">
            <list string="Nextcloud Documents" create="false" edit="false">
                <field name="name"/>
                <field name="res_model"/>
                <field name="res_name"/>
                <field name="project_code"/>
                <field name="project_name"/>
                <field name="task_code"/>
                <field name="task_name"/>
                <field name="crm_code"/>
                <field name="crm_name"/>
                <field name="uploaded_by"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <field name="upload_date"/>
                <field name="state"/>
                <field name="is_previewable" column_invisible="True"/>
                <field name="upload_kind"/>
                <field name="can_download" column_invisible="True"/>
                <field name="can_request_download" column_invisible="True"/>
                <field name="error_message" string="Hata Nedeni"/>
                <field name="nextcloud_path"/>
                <button name="action_preview" string="Önizle" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="state != 'uploaded' or not is_previewable"/>
                <button name="action_rename_wizard" string="Ad Değiştir" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_manager,base.group_system"/>
                <button name="action_download" string="İndir" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer,base.group_system" invisible="not can_download"/>
                <button name="action_request_download" string="İndirme Talep Et" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="not can_request_download"/>
                <button name="action_open_nextcloud" string="Nextcloud'da Aç" type="object" class="btn-link" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="state != 'uploaded'"/>
            </list>
        </field>
    </record>

    <record id="view_nextcloud_document_form" model="ir.ui.view">
        <field name="name">nextcloud.document.form</field>
        <field name="model">nextcloud.document</field>
        <field name="arch" type="xml">
            <form string="Nextcloud Document" create="false" edit="false">
                <header>
                    <button name="action_preview" string="Önizle" type="object" invisible="not is_previewable" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer"/>
                    <button name="action_rename_wizard" string="Ad Değiştir" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_manager,base.group_system"/>
                    <button name="action_download" string="İndir" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer,base.group_system" invisible="not can_download"/>
                    <button name="action_request_download" string="İndirme Talep Et" type="object" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer" invisible="not can_request_download"/>
                    <button name="action_open_nextcloud" string="Nextcloud'da Aç" type="object" class="oe_highlight" invisible="not nextcloud_url" groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,uploaded,error"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="res_model"/>
                        <field name="res_name"/>
                        <field name="project_code"/>
                        <field name="project_name"/>
                        <field name="task_code"/>
                        <field name="task_name"/>
                        <field name="crm_code"/>
                        <field name="crm_name"/>
                        <field name="uploaded_by"/>
                        <field name="upload_date"/>
                        <field name="file_size"/>
                        <field name="mime_type"/>
                        <field name="upload_kind"/>
                        <field name="category_id"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                        <field name="tag_sync_error"/>
                        <field name="can_download" invisible="1"/>
                        <field name="can_request_download" invisible="1"/>
                        <field name="is_image"/>
                        <field name="is_previewable"/>
                        <field name="nextcloud_path"/>
                        <field name="nextcloud_url"/>
                        <field name="error_message" invisible="state != 'error'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nextcloud_document" model="ir.actions.act_window">
        <field name="name">Tüm Nextcloud Dosyaları</field>
        <field name="res_model">nextcloud.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_nextcloud_document_search" model="ir.ui.view">
        <field name="name">nextcloud.document.search</field>
        <field name="model">nextcloud.document</field>
        <field name="arch" type="xml">
            <search string="Nextcloud Dosyaları">
                <field name="name"/>
                <field name="res_name"/>
                <field name="project_code"/>
                <field name="project_name"/>
                <field name="task_name"/>
                <field name="crm_name"/>
                <field name="uploaded_by"/>
                <filter
                    name="uploaded"
                    string="Yüklenenler"
                    domain="[('state', '=', 'uploaded')]"
                />
                <filter
                    name="errors"
                    string="Hatalılar"
                    domain="[('state', '=', 'error')]"
                />
                <group expand="0" string="Grupla">
                    <filter
                        name="group_state"
                        string="Durum"
                        context="{'group_by': 'state'}"
                    />
                    <filter
                        name="group_kind"
                        string="Tür"
                        context="{'group_by': 'upload_kind'}"
                    />
                    <filter
                        name="group_category"
                        string="Klasör Kategorisi"
                        context="{'group_by': 'category_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <menuitem
        id="menu_cloud_root"
        name="Cloud"
        action="action_nextcloud_document"
        sequence="45"
        web_icon="odoo_nextcloud_document_hub,static/description/icon.png"
        groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer,base.group_system"
    />
    <menuitem
        id="menu_cloud_all_documents"
        name="Tüm Dosyalar"
        parent="menu_cloud_root"
        action="action_nextcloud_document"
        sequence="10"
        groups="odoo_nextcloud_document_hub.group_nextcloud_document_viewer,base.group_system"
    />
</odoo>
