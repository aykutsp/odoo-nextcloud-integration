<odoo>
    <record id="module_category_nextcloud_document_hub" model="ir.module.category">
        <field name="name">Nextcloud Document Hub</field>
        <field name="description">Nextcloud dosya görüntüleme, indirme ve yükleme yetkileri.</field>
        <field name="sequence">45</field>
    </record>

    <record id="group_nextcloud_document_viewer" model="res.groups">
        <field name="name">Nextcloud Document Viewer</field>
        <field name="category_id" ref="module_category_nextcloud_document_hub"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_nextcloud_document_downloader" model="res.groups">
        <field name="name">Nextcloud Document Downloader</field>
        <field name="category_id" ref="module_category_nextcloud_document_hub"/>
        <field name="implied_ids" eval="[(4, ref('group_nextcloud_document_viewer'))]"/>
    </record>

    <record id="group_nextcloud_document_uploader" model="res.groups">
        <field name="name">Nextcloud Document Uploader</field>
        <field name="category_id" ref="module_category_nextcloud_document_hub"/>
        <field name="implied_ids" eval="[(4, ref('group_nextcloud_document_viewer'))]"/>
    </record>

    <record id="group_nextcloud_document_manager" model="res.groups">
        <field name="name">Nextcloud Document Manager</field>
        <field name="category_id" ref="module_category_nextcloud_document_hub"/>
        <field name="implied_ids" eval="[
            (4, ref('group_nextcloud_document_downloader')),
            (4, ref('group_nextcloud_document_uploader'))
        ]"/>
    </record>

    <record id="base.group_system" model="res.groups">
        <field
            name="implied_ids"
            eval="[(4, ref('group_nextcloud_document_manager'))]"
        />
    </record>

    <record id="nextcloud_document_rule_viewer" model="ir.rule">
        <field name="name">Nextcloud documents: linked record access is checked by the model</field>
        <field name="model_id" ref="model_nextcloud_document"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_nextcloud_document_viewer'))]"/>
    </record>

    <record id="nextcloud_download_request_rule_user" model="ir.rule">
        <field name="name">Nextcloud download requests: own</field>
        <field name="model_id" ref="model_nextcloud_download_request"/>
        <field name="domain_force">[('requester_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="nextcloud_download_request_rule_manager" model="ir.rule">
        <field name="name">Nextcloud download requests: managers</field>
        <field name="model_id" ref="model_nextcloud_download_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_nextcloud_document_manager'))]"/>
    </record>
</odoo>
